{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}",
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "ConnectionStrings": {
    "PostgreSQL": ""
  },
  "CloakBrowser": {
    "BaseUrl": "http://localhost:18000",
    "TimeoutSeconds": 60
  },
  "AI": {
    "BaseUrl": "https://api.siliconflow.cn/v1/chat/completions",
    "ApiKey": "",
    "Model": "Qwen/Qwen3-8B",
    "ThinkingLevel": null
  },
  "Crawl": {
    "ProxyAddress": null,
    "ProxyPort": 8080,
    "ProxyUsername": null,
    "ProxyPassword": null,
    "UserAgent": null,
    "MinTextLength": 200
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Password": "",
    "Database": 0,
    "Prefix": "deepcrawl",
    "DefaultTtl": "00:30:00"
  }
}
